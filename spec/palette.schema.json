{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sabotage.nosso.top/spec/palette.schema.json",
  "title": "Sabotage palette spec",
  "type": "object",
  "required": ["meta", "variants"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["name", "author", "version", "homepage", "license"],
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "version": { "type": "string" },
        "homepage": { "type": "string" },
        "license": { "type": "string" }
      }
    },
    "variants": {
      "type": "object",
      "required": ["dark", "light"],
      "additionalProperties": false,
      "properties": {
        "dark": { "$ref": "#/$defs/variant" },
        "light": { "$ref": "#/$defs/variant" }
      }
    }
  },
  "$defs": {
    "hex": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
    },
    "variant": {
      "type": "object",
      "required": ["appearance", "ui", "ansi", "syntax", "extra"],
      "additionalProperties": false,
      "properties": {
        "appearance": { "enum": ["dark", "light"] },
        "ui": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/hex" },
          "required": ["bg", "bgAlt", "bgHl", "fg", "fgDim", "comment", "selection", "cursor", "border", "accent"]
        },
        "ansi": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/hex" },
          "required": ["black", "red", "green", "yellow", "blue", "magenta", "cyan", "white", "brightBlack", "brightRed", "brightGreen", "brightYellow", "brightBlue", "brightMagenta", "brightCyan", "brightWhite"]
        },
        "syntax": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/hex" },
          "required": ["keyword", "string", "number", "function", "variable", "type", "constant", "comment", "operator", "punctuation", "tag", "attribute", "property", "class", "regex", "escape", "invalid"]
        },
        "extra": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/hex" },
          "required": ["orange", "pink", "purple", "error", "warning", "info", "success"]
        }
      }
    }
  }
}
